{
  "name": "tredi-sdk",
  "version": "0.1.0",
  "description": "Typed, ESM-first SDK for the Meta Threads API.",
  "type": "module",
  "license": "MIT",
  "author": "Ievgen Gnedko <fgnedko@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YOUR_GITHUB_USERNAME/tredi-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_GITHUB_USERNAME/tredi-sdk/issues"
  },
  "homepage": "https://github.com/YOUR_GITHUB_USERNAME/tredi-sdk#readme",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "keywords": [
    "threads",
    "meta",
    "threads-api",
    "sdk",
    "typescript",
    "esm"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
